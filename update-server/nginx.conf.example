# NightsEdge — example nginx config for serving Firefox updates
#
# Firefox updater queries:
#   /update/6/<product>/<version>/<buildid>/<build_target>/<locale>/<channel>/<os_version>/<system_capabilities>/<distribution>/<distribution_version>/update.xml
#
# We rewrite these to serve the correct per-platform update.xml.

server {
    listen 443 ssl http2;
    server_name updates.example.com;

    ssl_certificate     /etc/ssl/certs/updates.example.com.pem;
    ssl_certificate_key /etc/ssl/private/updates.example.com.key;

    root /var/www/nightsedge-updates;

    # Rewrite Firefox update check URLs to per-platform update.xml
    # Captures: $1=product $2=version $3=buildid $4=build_target $5=locale $6=channel
    location ~ ^/update/6/([^/]+)/([^/]+)/([^/]+)/([^/]+)/([^/]+)/([^/]+)/ {
        # Map build_target to our platform directories
        set $platform $4;

        # Serve the platform-specific update.xml
        try_files /$platform/update.xml /empty-update.xml =404;
    }

    # MAR file downloads
    location /mar/ {
        autoindex off;
    }

    # Empty update response (no update available)
    location = /empty-update.xml {
        default_type application/xml;
        return 200 '<?xml version="1.0" encoding="UTF-8"?>\n<updates></updates>';
    }
}
